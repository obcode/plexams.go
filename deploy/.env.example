# Copy to .env and fill in. Consumed by docker-compose.yml. NEVER commit the real .env.

# --- Deployed image tags (ghcr.io) ---
# The CI deploy job pins these to the released version on each release. For a manual
# rollback set an older tag here and run `docker compose up -d plexams` (or gui).
PLEXAMS_TAG=latest
GUI_TAG=latest

# --- MongoDB root credentials (also used in .plexams.yaml db.uri) ---
MONGO_USER=plexams
MONGO_PASSWORD=change-me-strong-password

# --- Public hostname (must match the DNS name + TLS cert + OIDC redirect URI) ---
SERVER_NAME=plexams.example.hm.edu

# --- GUI → backend endpoints (both go through nginx, never http://plexams:8080) ---
# Injected into the gui service (docker-compose.yml). Both MUST use https://<SERVER_NAME>/query
# so nginx sets the X-Remote-User header; with auth.enabled the backend rejects anything
# that bypasses nginx. The GUI reads them at runtime ($env/dynamic/*), so no CI build-arg
# is needed. PUBLIC_* also drives the wss:// subscription URL for the live generation logs.
PUBLIC_PLEXAMS_SERVER=https://plexams.example.hm.edu/query
PLEXAMS_SERVER=https://plexams.example.hm.edu/query

# --- OIDC client, registered with the HM IdP team (Zentrale IT) ---
# Redirect/callback URI to register: https://<SERVER_NAME>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=your-client-id
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret
# Cookie encryption secret (must be 16/24/32 chars — `openssl rand -base64 24` gives 32): `openssl rand -base64 24`
OAUTH2_PROXY_COOKIE_SECRET=change-me-random-32-bytes-base64
