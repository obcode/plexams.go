# Copy to .env and fill in. Consumed by docker-compose.yml. NEVER commit the real .env.

# --- Deployed image tags (ghcr.io) ---
# The CI deploy job pins these to the released version on each release. For a manual
# rollback set an older tag here and run `docker compose up -d plexams` (or gui).
PLEXAMS_TAG=latest
GUI_TAG=latest

# --- MongoDB root credentials (also used in .plexams.yaml db.uri) ---
MONGO_USER=plexams
MONGO_PASSWORD=change-me-strong-password

# --- Public hostname (must match the DNS name + TLS cert + OIDC redirect URI) ---
SERVER_NAME=plexams.example.hm.edu

# --- GUI → backend endpoints (two hops, two URLs — see docker-compose.yml gui env) ---
# Injected into the gui service. The GUI reads them at runtime ($env/dynamic/*), so no
# CI build-arg is needed.
#   PUBLIC_* → runs in the BROWSER (has the OIDC cookie): public URL through nginx. Also
#     drives the wss:// subscription URL for the live generation logs.
#   PLEXAMS_SERVER → runs in the SSR node server (NO cookie): must reach the backend
#     INTERNALLY, else oauth2-proxy bounces it to the sso.hm.edu login page and the GUI
#     parses that HTML as GraphQL ("result is not object or array" → 500). The GUI relays
#     the X-Remote-User nginx injected into its page request. Default already internal;
#     only override to the public URL if you must (then auth-gated SSR needs a cookie).
PUBLIC_PLEXAMS_SERVER=https://plexams.example.hm.edu/query
PLEXAMS_SERVER=http://plexams:8080/query

# --- OIDC client, registered with the HM IdP team (Zentrale IT) ---
# Redirect/callback URI to register: https://<SERVER_NAME>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=your-client-id
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret
# Cookie encryption secret (must be 16/24/32 chars — `openssl rand -base64 24` gives 32): `openssl rand -base64 24`
OAUTH2_PROXY_COOKIE_SECRET=change-me-random-32-bytes-base64

# --- Self-hosted GitHub Actions Runner (nur für den `gh-runner`-Service, Profil "runner") ---
# GitHub PAT, mit dem der Runner-Container Registration-Tokens selbst erneuert. Nötig nur,
# wenn du den Runner via `docker compose --profile runner up -d gh-runner` startest.
# Classic-PAT mit Scope `repo` + `workflow`, oder Fine-grained mit Repository-Permission
# "Administration: Read and write" auf obcode/plexams.go (+ ggf. plexams.gui).
GH_RUNNER_PAT=ghp_change-me
