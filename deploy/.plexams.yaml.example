# Server .plexams.yaml — copy to .plexams.yaml, fill in, mount into the plexams
# container (see docker-compose.yml). Secrets stay in THIS file, never in the DB or git.
#
# Only the deployment-relevant keys are shown here. The full reference (zpa, smtp,
# anny, jira, operational keys) is in ../docs/configuration.md — add what you use.

# Pin the semester on a fresh/empty database so the workspace can bootstrap; once a
# workspace exists you can drop this and switch semesters through the GUI (setSemester).
semester: 2026-SS

db:
  # Points at the mongo service in the compose network, with the root credentials
  # from .env (MONGO_USER / MONGO_PASSWORD). authSource=admin for the root user.
  uri: mongodb://plexams:change-me-strong-password@mongo:27017/?authSource=admin

server:
  port: "8080"
  # Production hardening: turns OFF the GraphQL playground and introspection, and
  # makes "/" serve nothing (the GUI is served by nginx). Keep true on the server.
  production: true
  # The real HTTPS origin of the GUI (same host as nginx). Used for CORS + websocket
  # origin checks. Must be the exact scheme+host the browser uses.
  allowedorigins:
    - https://plexams.example.hm.edu

# ============================================================
# Authentication / authorization
# ============================================================
# The backend trusts the identity header the nginx/oauth2-proxy (OIDC) proxy injects. It does NOT
# authenticate itself — so it must be reachable only via the proxy (compose: no
# published port). Authorization (roles) IS enforced here.
auth:
  # true on the server. false (or omitted) = local development: a full-access dev
  # user is injected and nothing is ever rejected (local operation stays unchanged).
  enabled: true

  # Header the proxy sets with the verified identity (the OIDC "email" claim).
  # Must match the nginx `proxy_set_header X-Remote-User` directive. Default: X-Remote-User.
  header: X-Remote-User
  displaynameHeader: X-Remote-Displayname

  # Local-dev only: the email used when auth.enabled=false. Ignored on the server.
  # devuser: vorname.nachname@hm.edu

  # Seed the authorization allow-list on FIRST boot only (when the users collection is
  # still empty). Afterwards manage users through the GUI (setUser/removeUser); this
  # list is ignored once the collection is non-empty. Roles (hierarchy ADMIN ⊇ PLANER
  # ⊇ VIEWER): VIEWER (read-only) | PLANER (full planning) | ADMIN (planning + user
  # management). Seed the two planners as ADMIN so they can open access to a wider
  # circle (add VIEWER users) later — at least one ADMIN is required for that.
  seedusers:
    - email: planer1@hm.edu
      name: Planer Eins
      role: ADMIN
    - email: planer2@hm.edu
      name: Planer Zwei
      role: ADMIN

# The planner (shared email sender identity) — separate from auth users above. Kept
# for the first boot; afterwards editable in the GUI (setPlaner). See configuration.md.
planer:
  name: Prüfungsplanung FK07
  email: planer1@hm.edu

# operator.* is the LOCAL audit identity for the multi-instance local setup. On the
# server the audit "who" comes from the OIDC principal instead, so operator.* is not
# needed here.

# Master key (KEK) for per-user secrets (each planner's Jira PAT), AES-256-GCM
# encrypted in the DB. Generate with `openssl rand -base64 32`. Stays in this file /
# env, never in the DB or git. Missing/invalid key => Jira-PAT operations fail closed.
secrets:
  key: change-me-openssl-rand-base64-32

# --- Add the sections you actually use (secrets stay here) ---
# zpa:  { baseurl: ..., token: ... }        # ZPA app token — shared, stays here
# smtp: { ... }
# anny: { token: ... }
# jira: { baseurl: https://jira.cc.hm.edu, project: FK07PP }
#   NOTE: no jira.token here — Jira PATs are per planner, entered on the GUI
#   "Mein Account" page and stored encrypted (needs secrets.key above).
