# Copy to .env and fill in. Step 1 needs the public hostname (must match the DNS name)
# plus the ACME/EAB credentials Caddy uses to fetch the certificate from the HM CA.
SERVER_NAME=plexams.example.hm.edu

# TLS via Caddy's ACME client against the HM CA (External Account Binding) — from the HM IT.
ACME_EMAIL=oliver.braun@hm.edu
ACME_DIRECTORY_URL=https://acme.hm.edu/directory
ACME_EAB_KID=your-eab-kid
ACME_EAB_HMAC_KEY=your-eab-hmac-key
