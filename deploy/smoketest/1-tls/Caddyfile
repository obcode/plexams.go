# Smoke test — Step 1: TLS/ACME only. Caddy serves a static "Hello World" over HTTPS and
# fetches the certificate itself from the HM ACME CA (EAB). No OIDC, no plexams, no mongo.
# Proves the DNS name, the certificate and the reverse-proxy host all work, before login.
#
# {$VAR} placeholders come from the environment (docker-compose.yml caddy env).
{
	email {$ACME_EMAIL}
	acme_ca {$ACME_DIRECTORY_URL}
	acme_eab {
		key_id {$ACME_EAB_KID}
		mac_key {$ACME_EAB_HMAC_KEY}
	}
}

{$SERVER_NAME} {
	header Content-Type "text/html; charset=utf-8"
	respond `<!doctype html>
	<meta charset="utf-8">
	<title>plexams — TLS-Test</title>
	<h1>Hello World &#128274;</h1>
	<p>HTTPS läuft auf <strong>{$SERVER_NAME}</strong>.</p>
	<p>Das Zertifikat kommt von der HM-ACME-CA (via Caddys ACME-Client/EAB). Wenn der Browser
	hier kein Warnschild zeigt, ist TLS korrekt aufgesetzt.</p>
	<p>Nächster Schritt: Login-Test mit Shibboleth/OIDC (siehe smoketest/2-login).</p>
	` 200
}
