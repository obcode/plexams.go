# Copy to .env and fill in. Step 2 adds the OIDC client.
# Redirect/callback URI to register with the HM IdP team: https://<SERVER_NAME>/oauth2/callback

SERVER_NAME=plexams.example.hm.edu

OAUTH2_PROXY_CLIENT_ID=your-client-id
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret
# Must be 16/24/32 chars — `openssl rand -base64 24` gives 32 (NOT `-base64 32`, that's 44):
# `openssl rand -base64 24`
OAUTH2_PROXY_COOKIE_SECRET=change-me-random-32-bytes-base64
