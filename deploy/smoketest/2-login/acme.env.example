# Copy to acme.env and fill in. Sourced by acme-setup.sh. NEVER commit the real file.
# All values come from the HM Zentrale IT (the HM ACME CA uses External Account
# Binding / EAB).

# The HM ACME directory URL (ask the IT for the exact value).
ACME_DIRECTORY_URL=https://acme.hm.edu/directory

# EAB credentials that bind your ACME account to the HM CA account.
ACME_EAB_KID=your-eab-kid
ACME_EAB_HMAC_KEY=your-eab-hmac-key

# Contact address for the ACME account.
ACME_EMAIL=oliver.braun@hm.edu
